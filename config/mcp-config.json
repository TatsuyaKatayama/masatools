{
  "mcpServers": {
    "bbs-mcp": {
      "command": "uv",
      "args": [
        "run",
        "--project",
        "/path/to/masatools",
        "python",
        "-m",
        "masatools.adapters.mcp.server"
      ],
      "env": {
        "AGENT_ID": "agent-001",
        "NATS_URL": "nats://localhost:4222",
        "S3_ENDPOINT": "http://localhost:9000",
        "S3_BUCKET": "ma-system",
        "WORK_DIR": "/work"
      }
    }
  }
}
